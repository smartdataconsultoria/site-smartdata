let aberto = false;
let iniciado = false;

function toggleChat() {
  aberto = !aberto;
  document.getElementById('sd-panel').classList.toggle('open', aberto);
  document.getElementById('sd-fab').classList.toggle('open', aberto);
  document.getElementById('sd-badge').classList.add('gone');
  if (aberto && !iniciado) {
    iniciado = true;
    setTimeout(() => mostrarEtapa('inicio'), 350);
  }
  if (aberto) setTimeout(() => document.getElementById('sd-txt').focus(), 400);
}

function mostrarEtapa(chave) {
  if (chave === '_wa') {
    window.open('https://wa.me/5581995426006', '_blank');
    return;
  }
  const etapa = FLUXO[chave];
  if (!etapa) return;

  // Typing fake
  const msgs = document.getElementById('sd-msgs');
  const typ = document.createElement('div');
  typ.className = 'sd-row bot';
  typ.innerHTML = `<div class="sd-av-sm">🤖</div><div class="sd-bbl"><div class="sd-typing"><i></i><i></i><i></i></div></div>`;
  msgs.appendChild(typ);
  rolar();

  setTimeout(() => {
    typ.remove();
    // Mensagem do bot
    const row = document.createElement('div');
    row.className = 'sd-row bot';
    const opts = etapa.opcoes && etapa.opcoes.length
      ? '<div class="sd-opts">' +
          etapa.opcoes.map(o =>
            `<button class="sd-opt ${o.cta ? 'cta' : ''}" onclick="clicarOpcao(this,'${o.prox}','${escH(o.label)}')">${o.label}</button>`
          ).join('') +
        '</div>'
      : '';
    row.innerHTML = `<div class="sd-av-sm">🤖</div><div><div class="sd-bbl">${etapa.bot.replace(/\n/g,'<br>')}</div>${opts}</div>`;
    msgs.appendChild(row);
    rolar();
  }, 900);
}

function clicarOpcao(btn, prox, label) {
  // Desabilita botões do grupo
  btn.closest('.sd-opts').querySelectorAll('.sd-opt').forEach(b => b.disabled = true);
  adicionarUser(label);
  setTimeout(() => mostrarEtapa(prox), 300);
}

function enviarTexto() {
  const txt = document.getElementById('sd-txt');
  const val = txt.value.trim();
  if (!val) return;
  txt.value = ''; txt.style.height = 'auto';
  adicionarUser(val);
  // Resposta genérica para texto livre
  setTimeout(() => {
    const typ = document.createElement('div');
    typ.className = 'sd-row bot';
    typ.innerHTML = `<div class="sd-av-sm">🤖</div><div class="sd-bbl"><div class="sd-typing"><i></i><i></i><i></i></div></div>`;
    document.getElementById('sd-msgs').appendChild(typ);
    rolar();
    setTimeout(() => {
      typ.remove();
      const row = document.createElement('div');
      row.className = 'sd-row bot';
      row.innerHTML = `
        <div class="sd-av-sm">🤖</div>
        <div>
          <div class="sd-bbl">Entendi! Para te ajudar melhor, o ideal é falar diretamente com nossa equipe. 😊<br><br>Escolha a melhor forma:</div>
          <div class="sd-opts">
            <button class="sd-opt cta" onclick="clicarOpcao(this,'whatsapp','💬 Falar no WhatsApp')">💬 Falar no WhatsApp</button>
            <button class="sd-opt" onclick="clicarOpcao(this,'inicio','◀ Ver menu')">◀ Ver menu</button>
          </div>
        </div>`;
      document.getElementById('sd-msgs').appendChild(row);
      rolar();
    }, 900);
  }, 200);
}

function adicionarUser(texto) {
  const msgs = document.getElementById('sd-msgs');
  const row = document.createElement('div');
  row.className = 'sd-row user';
  row.innerHTML = `<div class="sd-av-sm">👤</div><div class="sd-bbl">${texto.replace(/</g,'&lt;')}</div>`;
  msgs.appendChild(row);
  rolar();
}

function rolar() {
  const m = document.getElementById('sd-msgs');
  m.scrollTop = m.scrollHeight;
}

function escH(s) {
  return (s||'').replace(/'/g,"&#39;").replace(/"/g,"&quot;");
}

// Some badge após 7s
setTimeout(() => {
  const b = document.getElementById('sd-badge');
  if (b && !aberto) { b.style.transition='opacity .5s'; b.style.opacity='0'; setTimeout(()=>b.classList.add('gone'),500); }
}, 7000);
</script>
