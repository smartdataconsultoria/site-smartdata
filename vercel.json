{
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "renaux.smartdataconsultoria.com"
        }
      ],
      "destination": "/app/clientes/renaux/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "renaux.smartdataconsultoria.com"
        }
      ],
      "destination": "/app/clientes/renaux/:path*"
    }
  ]
}
