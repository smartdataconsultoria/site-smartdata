{
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "fdbfrepresentacoes.smartdataconsultoria.com" }],
      "destination": "/app/clientes/fdbf/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fdbfrepresentacoes.smartdataconsultoria.com" }],
      "destination": "/app/clientes/fdbf/:path*"
    }
  ]
}
